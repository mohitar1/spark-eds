{
  "info": {
    "_postman_id": "koassets-api-security-review",
    "name": "KO Assets API - Security Review",
    "description": "Comprehensive API collection for KO Assets platform security assessment.\n\n## Authentication\nAll authenticated endpoints require a valid `session` cookie obtained through the Microsoft Entra ID OAuth/OIDC flow.\n\n## Base URL\nProduction: https://koassets.adobecocacola.workers.dev\nPreview: https://preview-koassets.adobecocacola.workers.dev\nLocal: http://localhost:8787\n\n## API Categories\n- Internal APIs: Implemented in Cloudflare Worker\n- Proxied APIs: Forwarded to external services (Adobe DM, Fadel, AEM)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://koassets.adobecocacola.workers.dev",
      "type": "string"
    },
    {
      "key": "sessionCookie",
      "value": "YOUR_SESSION_COOKIE_VALUE",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Authentication",
      "description": "OAuth/OIDC authentication flow with Microsoft Entra ID. The session cookie is set after successful authentication.",
      "item": [
        {
          "name": "Login Redirect",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Initiates OAuth flow - redirects to Microsoft Entra ID login page. After successful authentication, redirects back with session cookie set."
          },
          "response": [
            {
              "name": "Redirect to IDP",
              "status": "Found",
              "code": 302,
              "header": [
                {
                  "key": "Location",
                  "value": "https://login.microsoftonline.com/..."
                }
              ],
              "body": ""
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Cookie",
                "value": "session={{sessionCookie}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            },
            "description": "Clears session cookie and optionally redirects to IDP logout."
          },
          "response": [
            {
              "name": "Logout Success",
              "status": "Found",
              "code": 302,
              "header": [
                {
                  "key": "Set-Cookie",
                  "value": "session=; Path=/; Expires=Thu, 01 Jan 1970 00:00:00 GMT"
                }
              ],
              "body": ""
            }
          ]
        }
      ]
    },
    {
      "name": "2. User API (Internal)",
      "description": "User session information API. Returns authenticated user details from the session cookie.",
      "item": [
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Cookie",
                "value": "session={{sessionCookie}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/user",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user"]
            },
            "description": "Returns the authenticated user's profile information including roles, permissions, and session expiration."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john.doe@coca-cola.com\",\n  \"country\": \"US\",\n  \"employeeType\": \"10\",\n  \"koid\": \"12345\",\n  \"company\": \"The Coca-Cola Company\",\n  \"permissions\": [\"preview\", \"admin-reports\"],\n  \"roles\": [\"employee\"],\n  \"countries\": [],\n  \"customers\": [],\n  \"brands\": [],\n  \"sessionExpiresInSec\": 21600\n}"
            },
            {
              "name": "Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"error\": \"Unauthorized\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "3. Saved Searches API (Internal - KV)",
      "description": "CRUD operations for user saved searches stored in Cloudflare KV. All keys are automatically scoped to the authenticated user.",
      "item": [
        {
          "name": "List Saved Search Keys",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Cookie",
                "value": "session={{sessionCookie}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/savedsearches/list?limit=100",
              "host": ["{{baseUrl}}"],
              "path": ["api", "savedsearches", "list"],
              "query": [
                {
                  "key": "limit",
                  "value": "100",
                  "description": "Maximum number of keys to return (default: 100)"
                }
              ]
            },
            "description": "Lists all saved search keys for the authenticated user."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"keys\": [\n    {\n      \"name\": \"user:john.doe@coca-cola.com:saved-searches\",\n      \"expiration\": null,\n      \"metadata\": null\n    }\n  ],\n  \"prefix\": \"user:john.doe@coca-cola.com:\",\n  \"count\": 1\n}"
            }
          ]
        },
        {
          "name": "Get Saved Searches",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Cookie",
                "value": "session={{sessionCookie}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/savedsearches/get",
              "host": ["{{baseUrl}}"],
              "path": ["api", "savedsearches", "get"]
            },
            "description": "Retrieves the saved searches for the authenticated user."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"key\": \"user:john.doe@coca-cola.com:saved-searches\",\n  \"value\": [\n    {\n      \"id\": \"search-123\",\n      \"name\": \"Coca-Cola Red Assets\",\n      \"searchTerm\": \"coca-cola red\",\n      \"filters\": {\"brand\": \"Coca-Cola\"},\n      \"dateCreated\": \"2024-01-15T10:30:00Z\"\n    }\n  ],\n  \"rawValue\": \"[...]\"\n}"
            },
            {
              "name": "Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"success\": false,\n  \"error\": \"Key not found\"\n}"
            }
          ]
        },
        {
          "name": "Save Searches",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Cookie",
                "value": "session={{sessionCookie}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"value\": [\n    {\n      \"id\": \"search-123\",\n      \"name\": \"Coca-Cola Red Assets\",\n      \"searchTerm\": \"coca-cola red\",\n      \"filters\": {\"brand\": \"Coca-Cola\"},\n      \"dateCreated\": \"2024-01-15T10:30:00Z\"\n    }\n  ],\n  \"metadata\": {\"version\": 1},\n  \"expirationTtl\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/savedsearches/set",
              "host": ["{{baseUrl}}"],
              "path": ["api", "savedsearches", "set"]
            },
            "description": "Saves or updates the user's saved searches."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"key\": \"user:john.doe@coca-cola.com:saved-searches\",\n  \"message\": \"Value set successfully\"\n}"
            }
          ]
        },
        {
          "name": "Delete Saved Searches",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Cookie",
                "value": "session={{sessionCookie}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/savedsearches/delete",
              "host": ["{{baseUrl}}"],
              "path": ["api", "savedsearches", "delete"]
            },
            "description": "Deletes the saved searches for the authenticated user."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"key\": \"user:john.doe@coca-cola.com:saved-searches\",\n  \"message\": \"Key deleted successfully\"\n}"
            }
          ]
        },
        {
          "name": "Get Report Metrics (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Cookie",
                "value": "session={{sessionCookie}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/savedsearches/report-metrics",
              "host": ["{{baseUrl}}"],
              "path": ["api", "savedsearches", "report-metrics"]
            },
            "description": "Returns aggregate metrics for saved searches across all users. Requires admin-reports permission."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"metrics\": {\n    \"totalUsers\": 1500,\n    \"usersWithSavedSearches\": 350,\n    \"totalSavedSearches\": 1200,\n    \"avgPerUser\": 3.43\n  },\n  \"charts\": {\n    \"savedSearchesByMonth\": [...],\n    \"distribution\": [...]\n  },\n  \"timestamp\": \"2024-01-15T10:30:00Z\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "4. Rights Requests API (Internal - KV)",
      "description": "Rights request management for restricted assets. Supports submitter and reviewer workflows.",
      "item": [
        {
          "name": "List User's Rights Requests",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Cookie",
                "value": "session={{sessionCookie}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/rightsrequests",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rightsrequests"]
            },
            "description": "Lists all rights requests submitted by the authenticated user."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"rights-request-1234567890\": {\n      \"rightsRequestID\": \"1234567890\",\n      \"rightsRequestSubmittedUserID\": \"john.doe@coca-cola.com\",\n      \"created\": \"Mon, 15 Jan 2024 10:30:00 GMT\",\n      \"rightsRequestDetails\": {...},\n      \"rightsRequestReviewDetails\": {\n        \"rightsRequestStatus\": \"In Progress\",\n        \"rightsReviewer\": \"reviewer@coca-cola.com\"\n      }\n    }\n  },\n  \"count\": 1\n}"
            }
          ]
        },
        {
          "name": "Create Rights Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Cookie",
                "value": "session={{sessionCookie}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"restrictedAssets\": [\n    {\n      \"assetId\": \"urn:aaid:aem:abc123\",\n      \"name\": \"Campaign Asset.jpg\"\n    }\n  ],\n  \"agencyType\": \"Associate\",\n  \"agencyName\": \"TCCC Marketing\",\n  \"contactName\": \"John Doe\",\n  \"contactEmail\": \"john.doe@coca-cola.com\",\n  \"contactPhone\": \"+1-555-0123\",\n  \"airDate\": \"2024-03-01\",\n  \"pullDate\": \"2024-06-01\",\n  \"selectedMarkets\": [{\"id\": 1, \"name\": \"North America\"}],\n  \"selectedMediaChannels\": [{\"id\": 1, \"name\": \"Digital\"}],\n  \"materialsRequiredDate\": \"2024-02-15\",\n  \"formatsRequired\": \"PSD, JPEG\",\n  \"usageRightsRequired\": {\"music\": true, \"talent\": false},\n  \"adaptationIntention\": \"None\",\n  \"budgetForMarket\": \"$50,000\",\n  \"exceptionOrNotes\": \"Urgent request\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rightsrequests",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rightsrequests"]
            },
            "description": "Creates a new rights request for restricted assets."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"rightsRequestID\": \"1234567890123456\",\n    \"rightsRequestSubmittedUserID\": \"john.doe@coca-cola.com\",\n    \"created\": \"Mon, 15 Jan 2024 10:30:00 GMT\",\n    \"rightsRequestDetails\": {...},\n    \"rightsRequestReviewDetails\": {\n      \"rightsRequestStatus\": \"Not Started\",\n      \"rightsReviewer\": \"\"\n    }\n  },\n  \"message\": \"Rights request created successfully\"\n}"
            }
          ]
        },
        {
          "name": "Update Request Status (Submitter)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Cookie",
                "value": "session={{sessionCookie}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"requestId\": \"1234567890\",\n  \"status\": \"User Canceled\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rightsrequests/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rightsrequests", "status"]
            },
            "description": "Allows submitter to cancel their own request. Only 'User Canceled' status is allowed."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {...},\n  \"message\": \"Request cancelled successfully\"\n}"
            }
          ]
        },
        {
          "name": "List All Rights Requests (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Cookie",
                "value": "session={{sessionCookie}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/rightsrequests/all",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rightsrequests", "all"]
            },
            "description": "Lists all rights requests across all users. Requires admin-reports permission."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {...},\n  \"count\": 150,\n  \"totalKeys\": 150\n}"
            },
            {
              "name": "Forbidden",
              "status": "Forbidden",
              "code": 403,
              "body": "{\n  \"success\": false,\n  \"error\": \"admin-reports permission required\"\n}"
            }
          ]
        },
        {
          "name": "List Reviews for Reviewer",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Cookie",
                "value": "session={{sessionCookie}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/rightsrequests/reviews",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rightsrequests", "reviews"]
            },
            "description": "Lists all reviews (assigned + unassigned) for the authenticated reviewer. Requires manage-rights or admin-rights permission."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {...},\n  \"count\": 10,\n  \"unassignedCount\": 3,\n  \"assignedCount\": 7\n}"
            }
          ]
        },
        {
          "name": "List Available Reviewers",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Cookie",
                "value": "session={{sessionCookie}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/rightsrequests/reviews/reviewers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rightsrequests", "reviews", "reviewers"]
            },
            "description": "Lists users who can be assigned as reviewers. Requires admin-rights permission."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": [\n    {\n      \"email\": \"reviewer1@coca-cola.com\",\n      \"permissions\": [\"manage-rights\"]\n    },\n    {\n      \"email\": \"admin@coca-cola.com\",\n      \"permissions\": [\"admin-rights\"]\n    }\n  ],\n  \"count\": 2\n}"
            }
          ]
        },
        {
          "name": "Assign Review",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Cookie",
                "value": "session={{sessionCookie}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"requestId\": \"1234567890\",\n  \"assigneeEmail\": \"reviewer@coca-cola.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rightsrequests/reviews/assign",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rightsrequests", "reviews", "assign"]
            },
            "description": "Assigns a review to a reviewer. Self-assignment requires manage-rights; assigning to others requires admin-rights."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {...},\n  \"message\": \"Review assigned to reviewer@coca-cola.com successfully\"\n}"
            }
          ]
        },
        {
          "name": "Update Review Status",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Cookie",
                "value": "session={{sessionCookie}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"requestId\": \"1234567890\",\n  \"status\": \"Done\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rightsrequests/reviews/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rightsrequests", "reviews", "status"]
            },
            "description": "Updates the status of an assigned review. Valid statuses: In Progress, User Canceled, RM Canceled, Quote Pending, Release Pending, Done. Requires manage-rights permission."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {...},\n  \"message\": \"Status updated successfully\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "5. Notifications API (Internal - KV)",
      "description": "RESTful CRUD operations for user notifications stored in Cloudflare KV.",
      "item": [
        {
          "name": "List Notifications",
