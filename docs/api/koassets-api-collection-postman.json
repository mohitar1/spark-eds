    {
      "name": "7. Dynamic Media API (Proxied to Adobe)",
      "description": "Proxied to Adobe Dynamic Media / ContentAI API (delivery-*.adobeaemcloud.com). Provides asset search, collection search, metadata, and rendition delivery. Search endpoints use ContentAI query format.",
      "item": [
        {
          "name": "Search Assets",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Cookie",
                "value": "session={{sessionCookie}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": [\n    {\n      \"and\": [\n        {\n          \"and\": [\n            {\n              \"match\": {\n                \"text\": \"coke\",\n                \"fields\": [\n                  \"assetMetadata.dc:title\",\n                  \"assetMetadata.dc:subject\",\n                  \"repositoryMetadata.repo:name\",\n                  \"assetMetadata.xcm:keywords\",\n                  \"assetMetadata.xcm:machineKeywords.value\",\n                  \"assetMetadata.dam:textContent\",\n                  \"assetMetadata.autogen:subject\",\n                  \"assetMetadata.autogen:description\",\n                  \"assetMetadata.autogen:title\",\n                  \"assetMetadata.tccc:keywords\"\n                ]\n              }\n            },\n            {\n              \"or\": [\n                {\n                  \"not\": [\n                    {\n                      \"exists\": {\n                        \"field\": \"assetMetadata.pur:expirationDate\"\n                      }\n                    }\n                  ]\n                },\n                {\n                  \"range\": {\n                    \"assetMetadata.pur:expirationDate\": {\n                      \"gt\": \"2026-02-17T21:37:43.011Z\"\n                    }\n                  }\n                }\n              ]\n            }\n          ]\n        },\n        {\n          \"and\": [\n            {\n              \"or\": [\n                {\n                  \"term\": {\n                    \"assetMetadata.tccc:contentType\": [\n                      \"marketing\"\n                    ]\n                  }\n                },\n                {\n                  \"term\": {\n                    \"assetMetadata.tccc:contentType\": [\n                      \"customers\"\n                    ]\n                  }\n                }\n              ]\n            }\n          ]\n        }\n      ]\n    }\n  ],\n  \"limit\": 24,\n  \"orderBy\": \"repositoryMetadata.repo:modifyDate desc\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/adobe/assets/contentai/search",
              "host": ["{{baseUrl}}"],
              "path": ["api", "adobe", "assets", "contentai", "search"]
            },
            "description": "Searches for assets using ContentAI search API. The worker applies authorization filters (tccc:includeInSearch, tccc:assetStatus) and expiration date filtering server-side before forwarding to Adobe."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"hits\": {\n    \"results\": [\n      {\n        \"assetId\": \"urn:aaid:aem:abc123\",\n        \"repositoryMetadata\": {\n          \"repo:name\": \"summer-campaign-hero.jpg\",\n          \"repo:modifyDate\": \"2026-01-15T10:30:00Z\"\n        },\n        \"assetMetadata\": {\n          \"dc:format\": \"image/jpeg\",\n          \"dc:title\": \"Summer Campaign Hero Image\"\n        }\n      }\n    ]\n  },\n  \"search_metadata\": {\n    \"totalCount\": {\n      \"total\": 42\n    }\n  },\n  \"cursor\": \"eyJhbGci...\"\n}"
            }
          ]
        },
        {
          "name": "Search Collections",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Cookie",
                "value": "session={{sessionCookie}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": [\n    {\n      \"match\": {\n        \"text\": \"\",\n        \"fields\": [\n          \"collectionMetadata.title\",\n          \"collectionMetadata.description\"\n        ]\n      }\n    }\n  ],\n  \"limit\": 50,\n  \"orderBy\": \"repositoryMetadata.repo:modifyDate desc\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/adobe/assets/contentai/collections/search",
              "host": ["{{baseUrl}}"],
              "path": ["api", "adobe", "assets", "contentai", "collections", "search"]
            },
            "description": "Searches collections using ContentAI search API. The server automatically applies authorization filters (ACL) to limit results to collections where the user is owner, editor, or viewer. Set the query text to filter by collection title/description."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"hits\": {\n    \"results\": [\n      {\n        \"collectionId\": \"col-123\",\n        \"collectionMetadata\": {\n          \"title\": \"Summer Campaign Assets\",\n          \"description\": \"Assets for the summer campaign\"\n        },\n        \"repositoryMetadata\": {\n          \"repo:modifyDate\": \"2026-01-15T10:30:00Z\"\n        }\n      }\n    ]\n  },\n  \"search_metadata\": {\n    \"totalCount\": {\n      \"total\": 5\n    }\n  },\n  \"cursor\": \"eyJhbGci...\"\n}"
            }
          ]
        },
