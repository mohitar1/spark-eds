              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "image/jpeg"
                },
                {
                  "key": "Content-Disposition",
                  "value": "attachment; filename=\"asset.jpg\""
                }
              ],
              "body": "(binary file data)"
            }
          ]
        },
        {
          "name": "Create Archive (Multi-asset Download)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Cookie",
                "value": "session={{sessionCookie}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-analytics-context",
                "value": "{\"downloadId\":\"dl-123\",\"assets\":[{\"assetId\":\"urn:aaid:aem:5feffccb-7249-434d-808d-d8523f03c6b7\",\"brand\":\"Coca-Cola\",\"campaign\":\"Summer 2024\",\"downloadType\":\"ready-to-use\",\"renditions\":[\"original\"]},{\"assetId\":\"urn:aaid:aem:9ff98e98-452d-4622-a06e-b12798d9975e\",\"brand\":\"Sprite\",\"campaign\":\"Summer 2024\",\"downloadType\":\"ready-to-use\",\"renditions\":[\"original\"]}]}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"assetId\": \"urn:aaid:aem:5feffccb-7249-434d-808d-d8523f03c6b7\",\n      \"includeRenditions\": [\n        \"original\"\n      ]\n    },\n    {\n      \"assetId\": \"urn:aaid:aem:9ff98e98-452d-4622-a06e-b12798d9975e\",\n      \"includeRenditions\": [\n        \"original\"\n      ]\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/adobe/assets/archives",
              "host": ["{{baseUrl}}"],
              "path": ["api", "adobe", "assets", "archives"]
            },
            "description": "Creates a ZIP archive containing multiple assets. The x-analytics-context header provides tracking metadata."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/zip"
                }
              ],
              "body": "(binary ZIP data)"
            }
          ]
        }
      ]
